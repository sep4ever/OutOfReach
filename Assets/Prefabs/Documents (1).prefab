  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 074096a67fe8360479f5bb1f6c25493c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Documents
  canInteract: 1
  id: 4
  documentLines:
  - "\u041E\u0422\u0427\u0401\u0422 \u041E\u0422 24 \u042F\u041D\u0412\u0410\u0420\u042F,
    19\u0425\u0425 \u0413\u041E\u0414.\n\n\u0410\u0440\u043C\u0438\u0438 \u043D\u0430\u0448\u0438\u0445
    \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u043E\u0442\u0441\u0442\u0443\u043F\u0438\u0442\u044C.
    \u041C\u044B \u043F\u043E\u0442\u0435\u0440\u043F\u0435\u043B\u0438 \u0441\u0442\u0440\u0430\u0448\u043D\u044B\u0435
    \u0443\u0431\u044B\u0442\u043A\u0438 \u0432 \u043B\u044E\u0434\u0441\u043A\u0438\u0445
    \u0440\u0435\u0441\u0443\u0440\u0441\u0430\u0445.\n\n\u0412\u0440\u0430\u0436\u0435\u0441\u043A\u0438\u0435
    \u0432\u043E\u0439\u0441\u043A\u0430 \u0448\u0442\u0443\u0440\u043C\u043E\u043C
    \u043E\u0441\u0430\u0434\u0438\u043B\u0438 \u0433\u043E\u0440\u043E\u0434. \u041D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u0438\u0437 \u043E\u0442\u0440\u044F\u0434\u0430
    \"\u041A\u0440\u0430\u0441\u043D\u044B\u0445\" \u0432\u0437\u044F\u043B\u0438
    \u0432 \u043F\u043B\u0435\u043D. \u0414\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0430\u044F
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u043C\u043D\u0435
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430.\n\n\u041A \u0433\u043E\u0440\u044F\u0447\u0435\u0439
    \u0442\u043E\u0447\u043A\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
    \u043F\u043E\u0434\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u0435."
