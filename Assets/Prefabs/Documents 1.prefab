  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 074096a67fe8360479f5bb1f6c25493c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Documents
  canInteract: 1
  id: 4
  documentLines:
  - "\u041E\u0422\u0427\u0401\u0422 \u041E\u0422 23 \u042F\u041D\u0412\u0410\u0420\u042F,
    19\u0425\u0425 \u0413\u041E\u0414.\n\n\u0420\u0430\u0434\u0438\u043E\u0441\u0442\u0430\u043D\u0446\u0438\u0438
    \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u043B\u0438 \u0441\u0432\u043E\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u044F \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u0442\u044C
    \u043E\u0442\u0447\u0451\u0442\u044B. \u042D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0442\u043E\u0436\u0435 \u0441\u043A\u043E\u0440\u043E
    \u043E\u0442\u043A\u043B\u044E\u0447\u0430\u0442.\n\n\u0421\u043C\u0435\u0440\u0442\u0438
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B, \u0431\u043E\u043B\u0435\u0435
    13 \u0441\u043E\u043B\u0434\u0430\u0442 \u043F\u043E\u0433\u0438\u0431\u043B\u043E,
    \u043E\u043A\u043E\u043B\u043E 51 \u0441\u043E\u043B\u0434\u0430\u0442\u0430
    \u0440\u0430\u043D\u0435\u043D\u044B. \u0413\u043E\u0440\u043E\u0434 \u043D\u0430\u043A\u0440\u044B\u043B
    \u043A\u0440\u043E\u0432\u0430\u0432\u043E-\u043A\u0440\u0430\u0441\u043D\u044B\u0439
    \u0442\u0443\u043C\u0430\u043D. \u041F\u043E\u0441\u0442\u0430\u0432\u043A\u0430
    \u043F\u0440\u043E\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u044F
    \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0435\u043D\u0430."
