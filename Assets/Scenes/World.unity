  m_EditorClassIdentifier: Assembly-CSharp::QuestHandling
  questTexts: {fileID: 1127123282}
  quests:
  - name: "\u041E\u043A\u043D\u043E."
    description: "\u041F\u0440\u043E\u0432\u0435\u0440\u044C \u0432\u0438\u0434 \u0438\u0437
      \u043E\u043A\u043D\u0430. \\n<align=right><size=55%><i>\u042F \u043D\u0435\u043D\u0430\u0432\u0438\u0436\u0443
      \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0432 \u043E\u043A\u043D\u043E...
      \u041D\u043E \u0438\u043D\u0430\u0447\u0435 \u044F \u0441\u0432\u0438\u0445\u043D\u0443\u0441\u044C.</i></size></align>"
    isCompleted: 0
  - name: "\u0420\u0430\u0431\u043E\u0442\u0430."
    description: "\u0417\u0430\u0439\u043C\u0438\u0441\u044C \u0440\u0430\u0431\u043E\u0442\u043E\u0439. 
      \\n<align=right><size=55%><i>\u041E\u043F\u044F\u0442\u044C... \u041E\u043F\u044F\u0442\u044C
      \u044D\u0442\u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B...
      \u041A\u043E\u0433\u0434\u0430 \u043E\u043D\u0438 \u0443\u0436\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0430\u0442\u0441\u044F?</i></size></align>"
    isCompleted: 0
  - name: "\u0421\u043E\u043D."
    description: "\u041E\u0442\u043E\u0441\u043F\u0438\u0441\u044C.  \\n<align=right><size=55%><i>\u041A\u0430\u043A
      \u0436\u0435 \u044F \u0443\u0441\u0442\u0430\u043B...</i></size></align>"
    isCompleted: 0
  - name: "\u041E\u043A\u043D\u043E."
    description: "\u041F\u0440\u043E\u0432\u0435\u0440\u044C \u0432\u0438\u0434 \u0438\u0437
      \u043E\u043A\u043D\u0430. \\n<align=right><size=55%><i>\u042F \u043D\u0435\u043D\u0430\u0432\u0438\u0436\u0443
      \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0432 \u043E\u043A\u043D\u043E...
      \u041D\u043E \u0438\u043D\u0430\u0447\u0435 \u044F \u0441\u0432\u0438\u0445\u043D\u0443\u0441\u044C.</i></size></align>"
    isCompleted: 0
  - name: "\u0420\u0430\u0431\u043E\u0442\u0430."
    description: "\u0417\u0430\u0439\u043C\u0438\u0441\u044C \u0440\u0430\u0431\u043E\u0442\u043E\u0439. 
      \\n<align=right><size=55%><i>\u041E\u043F\u044F\u0442\u044C... \u041E\u043F\u044F\u0442\u044C
      \u044D\u0442\u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B...
