    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435:\n\nE - \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0434\u0438\u0430\u043B\u043E\u0433 / \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435.\n\nEnter
    - \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u043E\u043A\u043D\u043E.\n\n\u0421\u0442\u0440\u0435\u043B\u043E\u0447\u043A\u0438/WASD
    - \u0445\u043E\u0434\u044C\u0431\u0430.\n\nQ - \u043E\u0442\u043A\u0440\u044B\u0442\u044C/\u0437\u0430\u043A\u0440\u044B\u0442\u044C
    \u043A\u0432\u0435\u0441\u0442\u044B.\n\nEnter - \u0417\u0430\u043A\u0440\u044B\u0442\u044C
    \u0434\u0438\u0430\u043B\u043E\u0433.\n\n\u041F\u0440\u0435\u0434\u0438\u0441\u043B\u043E\u0432\u0438\u0435:\n\n\u0414\u0430\u043D\u043D\u0430\u044F
    \u0438\u0433\u0440\u0430 \u0431\u044B\u043B\u0430 \u0441\u0434\u0435\u043B\u0430\u043D\u0430
    \u043C\u0435\u043D\u0435\u0435 \u0447\u0435\u043C \u0437\u0430 10 \u0434\u043D\u0435\u0439!
    \u041F\u043E\u0441\u0435\u043C\u0443, \u043C\u043E\u0436\u0435\u0442 \u0438\u043C\u0435\u0442\u044C
    \u0431\u0430\u0433\u0438, \u043E\u0448\u0438\u0431\u043A\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0441\u044E\u0436\u0435\u0442\u043D\u044B\u0435 \u0434\u044B\u0440\u044B. \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0438
